rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function signedInEmail() {
      return signedIn() && request.auth.token.email != null;
    }

    function isAdmin() {
      return signedIn() && (
        get(/databases/$(database)/documents/user_data/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/user_data/$(request.auth.uid)).data.role in ['admin', 'super_admin']
      );
    }

    function isOwnerByUid(field) {
      return signedIn() && resource.data[field] == request.auth.uid;
    }

    function isOwnerByEmail(field) {
      return signedInEmail() && resource.data[field] == request.auth.token.email;
    }

    function requestEmail() {
      return signedInEmail() ? request.auth.token.email : "";
    }

    match /portal_pre_registrations/{docId} {
      allow create: if
        request.resource.data.firstName is string &&
        request.resource.data.lastName is string &&
        request.resource.data.intent in ['reserve', 'donate'] &&
        request.resource.data.createdAt != null;
      allow read: if isAdmin() || (signedIn() && (
        resource.id == request.auth.uid ||
        resource.data.uid == request.auth.uid ||
        (signedInEmail() && resource.data.email == request.auth.token.email)
      ));
      allow update: if isAdmin() || (signedIn() && (
        resource.id == request.auth.uid ||
        resource.data.uid == request.auth.uid
      ));
      allow delete: if false;
    }

    match /user_data/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId &&
        !(request.resource.data.isAdmin == true) &&
        !(request.resource.data.role in ['admin', 'super_admin']));
      allow delete: if false;
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if false;
    }

    match /founderApplications/{applicationId} {
      allow read: if isAdmin() || isOwnerByUid("userId") || isOwnerByEmail("email") || isOwnerByEmail("purchaseEmail");
      allow create, update: if signedInEmail() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.email == requestEmail() &&
        request.resource.data.purchaseEmail == requestEmail() &&
        request.resource.data.publicFounderId is string &&
        request.resource.data.paymentId is string &&
        request.resource.data.chariowOrderReference is string &&
        request.resource.data.claimedAmount is number &&
        request.resource.data.claimedCurrency is string &&
        request.resource.data.purchaseDate is string &&
        request.resource.data.paymentMethod is string &&
        request.resource.data.receiptReference is string &&
        request.resource.data.founderLevel in ['supporter', 'builder', 'pioneer', 'legacy'] &&
        request.resource.data.status == 'pending' &&
        request.resource.data.verificationMethod == 'chariow_api_verified' &&
        request.resource.data.termsAccepted == true &&
        request.resource.data.createdAt is string &&
        request.resource.data.updatedAt is string &&
        (
          !exists(/databases/$(database)/documents/founderApplications/$(applicationId)) ||
          (
            resource.data.userId == request.auth.uid &&
            !(resource.data.status in ['approved', 'rejected']) &&
            !(resource.data.founderId is string && resource.data.founderId != '')
          )
        );
      allow delete: if false;
    }

    match /founderReservations/{reservationId} {
      allow create: if
        request.resource.data.publicFounderId is string &&
        request.resource.data.publicFounderId.matches('^COF-[0-9]{4}-[0-9]{6}$') &&
        request.resource.data.firstName is string &&
        request.resource.data.lastName is string &&
        request.resource.data.displayName is string &&
        request.resource.data.status == 'not_verified' &&
        request.resource.data.activationStatus == 'awaiting_payment' &&
        request.resource.data.source in ['founders_portal', 'founders_portal_client'] &&
        request.resource.data.paymentId == '' &&
        request.resource.data.applicationId == '' &&
        request.resource.data.founderId == '' &&
        request.resource.data.userId == '' &&
        request.resource.data.email == '' &&
        request.resource.data.createdAt is string &&
        request.resource.data.updatedAt is string;
      allow update: if signedInEmail() &&
        resource.data.publicFounderId == request.resource.data.publicFounderId &&
        !(resource.data.founderId is string && resource.data.founderId != '') &&
        (
          resource.data.userId == '' || resource.data.userId == request.auth.uid
        ) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.email == requestEmail() &&
        request.resource.data.paymentId is string &&
        request.resource.data.applicationId is string &&
        request.resource.data.founderId is string &&
        request.resource.data.status in ['pending_review', 'verified'] &&
        request.resource.data.activationStatus in ['pending_review', 'active'] &&
        request.resource.data.updatedAt is string;
      allow read: if isAdmin() || isOwnerByUid("userId") || isOwnerByEmail("email");
      allow delete: if false;
    }

    match /founders/{founderId} {
      allow read: if
        isAdmin() ||
        isOwnerByUid("userId") ||
        isOwnerByEmail("email") ||
        (
          resource.data.publicFounderId is string &&
          !(resource.data.documentRole == 'schema')
        );
      allow create, update: if signedInEmail() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.email == requestEmail() &&
        request.resource.data.publicFounderId is string &&
        request.resource.data.publicFounderId.matches('^COF-[0-9]{4}-[0-9]{6}$') &&
        request.resource.data.paymentId is string &&
        request.resource.data.applicationId is string &&
        request.resource.data.founderLevel in ['supporter', 'builder', 'pioneer', 'legacy'] &&
        request.resource.data.status == 'active' &&
        request.resource.data.certificateStatus == 'active' &&
        request.resource.data.certificateNumber is string &&
        request.resource.data.joinedAt is string &&
        request.resource.data.issuedAt is string &&
        request.resource.data.createdAt is string &&
        request.resource.data.updatedAt is string &&
        (
          !exists(/databases/$(database)/documents/founders/$(founderId)) ||
          (
            resource.data.userId == request.auth.uid &&
            resource.data.publicFounderId == request.resource.data.publicFounderId &&
            !(resource.data.status in ['revoked', 'suspended'])
          )
        );
      allow delete: if false;
    }

    match /founderPayments/{paymentId} {
      allow read: if isAdmin() || isOwnerByUid("userId") || isOwnerByEmail("customerEmail");
      allow create, update: if signedInEmail() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.customerEmail == requestEmail() &&
        request.resource.data.provider == 'chariow' &&
        request.resource.data.providerSaleId is string &&
        request.resource.data.amount is number &&
        request.resource.data.currency is string &&
        request.resource.data.paymentStatus == 'success' &&
        request.resource.data.saleStatus == 'completed' &&
        request.resource.data.verified == true &&
        request.resource.data.verificationSource == 'client_verified_via_backend' &&
        request.resource.data.founderReferenceId is string &&
        request.resource.data.activationStatus == 'pending_review' &&
        request.resource.data.founderLevel in ['supporter', 'builder', 'pioneer', 'legacy'] &&
        request.resource.data.createdAt is string &&
        request.resource.data.updatedAt is string &&
        (
          !exists(/databases/$(database)/documents/founderPayments/$(paymentId)) ||
          (
            resource.data.userId == request.auth.uid &&
            !(resource.data.founderId is string && resource.data.founderId != '')
          )
        );
      allow delete: if false;
    }

    match /founderCredentialHistory/{historyId} {
      allow read: if isAdmin() || isOwnerByUid("userId");
      allow write: if false;
    }

    match /founderAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || isOwnerByUid("userId");
      allow update: if isAdmin() || isOwnerByUid("userId");
      allow create, delete: if false;
    }
  }
}
