rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /founders/{founderId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
